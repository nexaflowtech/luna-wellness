{
  "expo": {
    "name": "luna-wellness",
    "slug": "luna-wellness",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lunawellness",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#080B14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nexaflowtech.lunawellness"
    },
    "android": {
      "versionCode": 4,
      "adaptiveIcon": {
        "backgroundColor": "#080B14",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "splash": {
        "image": "./assets/splash.png",
        "resizeMode": "cover",
        "backgroundColor": "#080B14"
      },
      "package": "com.nexaflowtech.lunawellness",
      "googleServicesFile": "./google-services.json",
      "jsEngine": "hermes"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "kotlinVersion": "2.1.20",
            "kspVersion": "2.1.20-1.0.32",
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "minSdkVersion": 24
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "71ee249a-8dfc-4c61-9e9c-50c8d29472e2"
      }
    },
    "owner": "nexaflowtech007",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/71ee249a-8dfc-4c61-9e9c-50c8d29472e2",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    }
  }
}